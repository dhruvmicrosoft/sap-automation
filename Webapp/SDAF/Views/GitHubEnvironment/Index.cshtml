@model GHEnvironmentModel[]

@{
    ViewBag.Title = "GitHub Environments";
}

@* Notification auto-dismiss is handled in wwwroot/js/site.js *@

<fluent-breadcrumb>
    <fluent-breadcrumb-item href="@Url.Action("Index", "Home")">Home</fluent-breadcrumb-item>
    <fluent-breadcrumb-item href="@Url.Action("Index", "GitHubEnvironment")">Environments</fluent-breadcrumb-item>
</fluent-breadcrumb>

<div class="text-center">
    <h2>Existing environments</h2>
</div>

@if (TempData["success"] != null)
{
    <div class="notificationContainer alert-success" role="alert" data-timeout="5000">
        <div class="notificationInner">
            <span class="notificationText">@TempData["success"]</span>
            <button type="button" class="close" aria-label="Close">
                <span aria-hidden="true">&times;</span>
            </button>
        </div>
    </div>
}
@if (TempData["error"] != null)
{
    <div class="notificationContainer alert-danger" role="alert" data-timeout="10000">
        <div class="notificationInner">
            <span class="notificationText">@TempData["error"]</span>
            <button type="button" class="close" aria-label="Close">
                <span aria-hidden="true">&times;</span>
            </button>
        </div>
    </div>
}

<div class="cards">
    @foreach (var environment in Model)
    {
        <fluent-card>
            <div class="card-inner">
                <h4>@environment.Name</h4>
                <fluent-anchor style="width: 100%;" href="@Url.Action("Edit", "GitHubEnvironment", new { name = environment.Name })">
                    View
                </fluent-anchor>
            </div>
        </fluent-card>
    }
</div>

<p>
    <fluent-anchor appearance="accent" href="@Url.Action("Create", "GitHubEnvironment")">
        <i class="ms-Icon ms-Icon--Add" aria-hidden="true"></i> Create
    </fluent-anchor>
</p>
